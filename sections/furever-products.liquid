<section class="furever-products">
  <div class="page-width">
    <div class="section-heading">
      <p class="section-kicker">Shopify catalog</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      {% if section.settings.body != blank %}
        <p>{{ section.settings.body }}</p>
      {% endif %}
    </div>

    {% if section.settings.collection != blank and collections[section.settings.collection].products_count > 0 %}
      <div class="product-grid">
        {% for product in collections[section.settings.collection].products limit: 3 %}
          <article class="product-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', alt: product.featured_image.alt }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              <p>{{ product.price | money }}</p>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="product-grid product-grid--placeholder">
        <article class="product-card">
          <div class="product-card__media"></div>
          <h3>Product placeholder</h3>
          <p>Add products in Shopify to replace this card.</p>
        </article>
        <article class="product-card">
          <div class="product-card__media"></div>
          <h3>Collection placeholder</h3>
          <p>Choose a collection in the theme editor.</p>
        </article>
        <article class="product-card">
          <div class="product-card__media"></div>
          <h3>Design placeholder</h3>
          <p>Ready for the next visual pass.</p>
        </article>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Furever products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product space"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Connect Shopify products here when the catalog is ready."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Furever products"
    }
  ]
}
{% endschema %}
